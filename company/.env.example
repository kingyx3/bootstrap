# Copy to .env (or export directly) and fill in your key.
ANTHROPIC_API_KEY=sk-ant-...

# --- Project repository (name it at inception) -----------------------------
# The GitHub repo this company works on. owner/name, or a full https/git URL.
# Leave empty to have engineers build greenfield in ./workspace instead.
PROJECT_REPO=your-org/your-product
# Token with access to PROJECT_REPO (clone/push, and the GitHub MCP server if
# enabled). A fine-grained PAT scoped to just this repo is ideal.
GITHUB_TOKEN=ghp_...
# Optional: also expose the official GitHub MCP server to engineers (needs Docker):
# ENABLE_GITHUB_MCP=1

# --- Optional model / scale overrides (defaults shown) ---------------------
# CEO_MODEL=claude-opus-4-8
# MANAGER_MODEL=claude-opus-4-8
# ENGINEER_MODEL=claude-sonnet-5
# MAX_ENGINEERS=3
